# === Nidus Core Master GitIgnore (2026) ===

# --- Security & Secrets (CRITICAL) ---
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12
*.cer

# --- Python / Backend ---
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/
.python-version
*.db
*.sqlite3

# --- Node.js / Frontend (Next.js) ---
node_modules/
.next/
out/
build/
.eslintcache
.turbo/
.vercel/
npm-debug.log*
yarn-error.log*

# --- Docker & Infrastructure ---
.docker-data/
*.log
docker-compose.override.yml

# --- OS & Editors ---
.DS_Store
Thumbs.db
.vscode/
.idea/
.cursorignore
*.swp